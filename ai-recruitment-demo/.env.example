# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Datadog
# DD_API_KEY is read by the Datadog agent, not by ddtrace directly.
# ddtrace sends traces to a local agent (default: localhost:8126).
# Set DD_SERVICE, DD_ENV, and DD_VERSION to tag your traces in the Datadog UI.
DD_API_KEY=your_datadog_api_key_here
DD_SERVICE=ai-recruitment-demo
DD_ENV=development
DD_VERSION=0.1.0

# App
APP_ENV=development
